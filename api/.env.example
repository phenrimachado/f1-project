APP_NAME="F1 Insights"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Nomes de host = nomes dos servicos no docker-compose.yml (nao localhost)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=f1_project
DB_USERNAME=f1_user
DB_PASSWORD=secret

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Dominio base da API publica que vamos consumir
OPENF1_BASE_URL=https://api.openf1.org/v1

# CORS - libera o front local
FRONTEND_URL=http://localhost:3000
